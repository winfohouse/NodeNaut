{
  "manifest_version": 3,
  "name": "NodeNaut",
  "version": "0.2.3",
  "description": "Elite Programmable Browser Workflow & Smart Form Automation Platform",
  "permissions": [
    "storage",
    "sidePanel",
    "tabs",
    "scripting",
    "activeTab",
    "offscreen",
    "webNavigation",
    "notifications",
    "alarms",
    "history",
    "management",
    "bookmarks",
    "downloads",
    "cookies"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "index.html"
  },
  "action": {
    "default_title": "Open NodeNaut Sidepanel"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["assets/content.js"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "spa-bridge.js",
        "assets/*.js",
        "assets/*.css",
        "assets/*.wasm"
      ],
      "matches": ["<all_urls>"]
    }
  ],
  "sandbox": {
    "pages": ["sandbox.html"]
  }
}
