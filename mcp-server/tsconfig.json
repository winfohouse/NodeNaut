{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "outDir": "./dist",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "declaration": true,
    "sourceMap": true,
    "typeRoots": ["./node_modules/@types"],
    "types": ["node"]
  },
  "files": [
    "src/index.ts",
    "src/bridge.ts",
    "src/dashboard-html.ts"
  ]
}
